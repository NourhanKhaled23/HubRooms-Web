@page
@model LoginModel
@{
    ViewData["Title"] = "Sign in";
}

<div class="row justify-content-center" style="padding-top: 2rem;">
    <div class="col-lg-5">
        <div class="adv-card">
            <div class="adv-card-header">
                <div>
                    <p class="adv-kicker">Welcome back</p>
                    <h2>Sign in to Advanced Chat</h2>
                </div>
            </div>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" style="font-size:0.85rem"></div>

                <div class="adv-field" style="margin-top:0">
                    <label asp-for="Input.Email"></label>
                    <input asp-for="Input.Email" class="form-control adv-input" autocomplete="username" placeholder="you@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger" style="font-size:0.85rem"></span>
                </div>

                <div class="adv-field">
                    <label asp-for="Input.Password"></label>
                    <input asp-for="Input.Password" class="form-control adv-input" autocomplete="current-password" placeholder="Enter password" />
                    <span asp-validation-for="Input.Password" class="text-danger" style="font-size:0.85rem"></span>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="Input.RememberMe" class="form-check-input" />
                    <label asp-for="Input.RememberMe" class="form-check-label">Remember me</label>
                </div>

                <button type="submit" class="btn btn-primary adv-action w-100">
                    <i class="bi bi-box-arrow-in-right me-1"></i>Sign in
                </button>
            </form>

            <div class="mt-3 text-center" style="font-size:0.88rem; color:var(--text-secondary)">
                Don't have an account?
                <a asp-area="Identity" asp-page="/Account/Register" style="color:var(--accent); font-weight:600; text-decoration:none">Register</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
