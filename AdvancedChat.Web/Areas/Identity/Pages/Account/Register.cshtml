@page
@model RegisterModel
@{
    ViewData["Title"] = "Create account";
}

<div class="row justify-content-center" style="padding-top: 2rem;">
    <div class="col-lg-5">
        <div class="adv-card">
            <div class="adv-card-header">
                <div>
                    <p class="adv-kicker">Get started</p>
                    <h2>Create your account</h2>
                </div>
            </div>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" style="font-size:0.85rem"></div>

                <div class="adv-field" style="margin-top:0">
                    <label asp-for="Input.Email"></label>
                    <input asp-for="Input.Email" class="form-control adv-input" autocomplete="email" placeholder="you@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger" style="font-size:0.85rem"></span>
                </div>

                <div class="adv-field">
                    <label asp-for="Input.Password"></label>
                    <input asp-for="Input.Password" class="form-control adv-input" autocomplete="new-password" placeholder="At least 6 characters" />
                    <span asp-validation-for="Input.Password" class="text-danger" style="font-size:0.85rem"></span>
                </div>

                <div class="adv-field">
                    <label asp-for="Input.ConfirmPassword"></label>
                    <input asp-for="Input.ConfirmPassword" class="form-control adv-input" autocomplete="new-password" placeholder="Confirm your password" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger" style="font-size:0.85rem"></span>
                </div>

                <button type="submit" class="btn btn-primary adv-action w-100">
                    <i class="bi bi-person-plus me-1"></i>Create account
                </button>
            </form>

            <div class="mt-3 text-center" style="font-size:0.88rem; color:var(--text-secondary)">
                Already have an account?
                <a asp-area="Identity" asp-page="/Account/Login" style="color:var(--accent); font-weight:600; text-decoration:none">Sign in</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
