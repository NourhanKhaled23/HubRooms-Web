@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="error-page">
    <div class="error-icon">
        <i class="bi bi-exclamation-triangle-fill"></i>
    </div>
    <h1 class="text-danger">Something went wrong</h1>
    <p class="error-detail">An error occurred while processing your request. Please try again or contact support if the problem persists.</p>

    @if (Model.ShowRequestId)
    {
        <p style="margin-top: 1rem;">
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <a class="btn btn-primary adv-action mt-3" asp-controller="Home" asp-action="Index">
        <i class="bi bi-house-door me-1"></i> Back to Home
    </a>
</div>
